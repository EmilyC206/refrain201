# HubSpot (Private App token; create in HubSpot Settings → Integrations → Private Apps)
HUBSPOT_PRIVATE_APP_TOKEN=

# Local paths
COLDLEAD_DB_PATH=./data/coldlead.sqlite
COLDLEAD_CONFIG_PATH=./coldlead.yaml

# Optional routing: map tiers to HubSpot owner IDs
# Example: COLDLEAD_OWNER_MAP=hot:12345,warm:67890,cold:
COLDLEAD_OWNER_MAP=

# HTTP settings
COLDLEAD_HTTP_TIMEOUT_S=10
COLDLEAD_HTTP_UA=coldlead/0.1 (+https://example.invalid)
