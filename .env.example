# HubSpot Private App token — create in HubSpot Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read/write, crm.objects.companies.read/write,
#                  crm.schemas.contacts.read/write, crm.schemas.companies.read/write
HUBSPOT_ACCESS_TOKEN=

# Optional enrichment API keys — pipeline skips those steps if left blank
HUNTER_API_KEY=

# Wikidata SPARQL (no key required). Strongly recommended: set a descriptive UA.
WIKIDATA_USER_AGENT=refrain201/0.1 (contact: you@example.com)
# Optional: override SPARQL endpoint (default https://query.wikidata.org/sparql)
WIKIDATA_ENDPOINT=
# Optional: SPARQL timeout (seconds)
WIKIDATA_TIMEOUT_S=30

# Local paths
DB_PATH=./db/enrichment.db

# Pipeline behaviour
BATCH_SIZE=50
DAILY_HS_CALL_CAP=38000
ENRICH_INTERVAL_HOURS=4

# Watchdog email alerts (optional — prints to stdout if not configured)
WATCHDOG_SMTP_HOST=smtp.gmail.com
WATCHDOG_SMTP_PORT=587
WATCHDOG_SMTP_USER=
WATCHDOG_SMTP_PASSWORD=
WATCHDOG_NOTIFY_EMAIL=
